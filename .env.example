ANTHROPIC_API_KEY=none
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_MODEL_CODE=qwen2.5-coder:7b
DB_PATH=./envirofix.db
SCAN_INTERVAL_MINUTES=15
PORT=7070

# Controls whether the /analyse endpoint calls a local Ollama model or skips
# straight to the rule-based fallback (real scan data, no LLM). Set to false
# for low-resource hosts that don't have Ollama running (mock AI mode).
USE_OLLAMA=false
